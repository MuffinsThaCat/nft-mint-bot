# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# RPC Provider Keys (optional but recommended)
ALCHEMY_KEY=your_alchemy_key_here
QUICKNODE_KEY=your_quicknode_key_here
INFURA_KEY=your_infura_key_here

# Etherscan API Keys (for ABI fetching)
ETHERSCAN_API_KEY=your_etherscan_key_here
BASESCAN_API_KEY=your_basescan_key_here
ARBISCAN_API_KEY=your_arbiscan_key_here
POLYGONSCAN_API_KEY=your_polygonscan_key_here
OPTIMISTIC_ETHERSCAN_API_KEY=your_optimistic_etherscan_key_here

# Database Encryption
# IMPORTANT: This password encrypts all private keys. NEVER commit this.
# Set via environment variable or enter at runtime
# DB_PASSWORD=your_secure_password_here

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
